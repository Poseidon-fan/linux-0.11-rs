{
    "name": "Linux-0.11-rs dev container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "vadimcn.vscode-lldb",
                "tamasfe.even-better-toml",
                "serayuzgur.crates",
                "13xforever.language-x86-64-assembly"
            ],
            "settings": {
                "rust-analyzer.linkedProjects": [
                    "kernel/Cargo.toml",
                    "user_lib/Cargo.toml",
                    "miniximg/Cargo.toml",
                    "mbrkit/Cargo.toml"
                ],
                "rust-analyzer.check.allTargets": false,
                "rust-analyzer.procMacro.enable": true,
                "editor.formatOnSave": true,
                "rust-analyzer.check.command": "clippy"
            }
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "sh -x ${containerWorkspaceFolder}/.devcontainer/setup.sh"
}
